<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_patient_list" model="ir.ui.view">
        <field name="name">hms.patient.list</field>
        <field name="model">hms.patient</field>
        <field name="arch" type="xml">
            <tree>
                <field name="first_name"/>
                <field name="last_name"/>
                <field name="email"/>  
                <field name="age"/>
                <field name="department_id"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="view_patient_form" model="ir.ui.view">
        <field name="name">hms.patient.form</field>
        <field name="model">hms.patient</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_set_good" string="Set to Good" type="object" class="oe_highlight" invisible="state == 'Good'"/>
                    <button name="action_set_fair" string="Set to Fair" type="object" invisible="state == 'Fair'"/>
                    <button name="action_set_serious" string="Set to Serious" type="object" invisible="state == 'Serious'"/>
                    <field name="state" widget="statusbar" statusbar_visible="Undetermined,Good,Fair,Serious"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="first_name"/>
                            <field name="last_name"/>
                            <field name="email"/> 
                            <field name="birth_date"/>
                            <field name="age"/>
                            <field name="blood_type"/>
                            <field name="department_id" domain="[('is_opened', '=', True)]"/>
                            <field name="doctor_ids" readonly="not department_id" widget="many2many_tags" groups="hms.hms_group_manager"/>
                        </group>
                        <group>
                            <field name="pcr"/>
                            <field name="cr_ratio"/>
                            <field name="history" invisible="age &lt; 50"/>
                            <field name="department_capacity"/>
                            <field name="address"/>
                            <field name="image" widget="image"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Logs">
                            <field name="log_ids" readonly="1">
                                <tree>
                                    <field name="create_uid" string="Created By"/>
                                    <field name="create_date" string="Date"/>
                                    <field name="description"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_patient" model="ir.actions.act_window">
        <field name="name">Patients</field>
        <field name="res_model">hms.patient</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_patient" name="Patients" parent="menu_hms_root" action="action_patient"/>
</odoo>